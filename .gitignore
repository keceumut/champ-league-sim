# Bootstrap cache (auto-generated by artisan optimize)
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

# Storage - logs
/storage/logs/*
!/storage/logs/.gitkeep

# Storage - framework runtime files
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/testing/*
!/storage/framework/testing/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep
/storage/framework/compiled.php
/storage/framework/config.php
/storage/framework/down
/storage/framework/events.scanned.php
/storage/framework/maintenance.php
/storage/framework/routes.php
/storage/framework/routes.scanned.php
/storage/framework/schedule-*
/storage/framework/services.json

# Storage - app uploads
/storage/app/*
!/storage/app/private/
!/storage/app/public/
